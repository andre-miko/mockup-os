{
  "name": "ai-mockup-kit",
  "version": "0.1.0",
  "private": false,
  "description": "A React framework for humans and AI agents to generate, refine, validate, and hand off production-quality product mockups as real JSX/TSX routes.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "validate": "tsx --tsconfig ./tsconfig.app.json ../../scripts/validate-registry.ts",
    "docs:build": "tsx --tsconfig ./tsconfig.app.json ../../scripts/build-docs.ts",
    "handoff": "tsx --tsconfig ./tsconfig.app.json ../../scripts/build-handoff.ts",
    "snapshot": "tsx --tsconfig ./tsconfig.app.json ../../scripts/snapshot-screens.ts",
    "sidecar": "tsx --tsconfig ./tsconfig.app.json ../../scripts/sidecar/server.ts",
    "preflight": "tsx --tsconfig ./tsconfig.app.json ../../scripts/preflight.ts",
    "dev:all": "npm-run-all --parallel dev sidecar"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@fastify/cors": "^9.0.1",
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "fastify": "^4.29.1",
    "jsdom": "^25.0.0",
    "npm-run-all": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.11",
    "ts-morph": "^28.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
